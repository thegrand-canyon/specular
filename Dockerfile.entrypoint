# Use shell script ENTRYPOINT (harder for Railway to override)
FROM node:22-slim

WORKDIR /app

COPY package*.json ./
RUN npm install --production

COPY . .
RUN npm run compile || true

# Copy startup script
COPY start.sh /start.sh
RUN chmod +x /start.sh

ENV NODE_ENV=production
ENV PORT=3001
ENV NODE_OPTIONS="--max-old-space-size=512"

EXPOSE 3001

# ENTRYPOINT is harder to override than CMD
ENTRYPOINT ["/start.sh"]
